        "jsonBody": "={{ JSON.stringify({ title: $json.todoTitle, description: $json.todoDescription, emailFrom: $json.emailFrom, emailDate: $json.emailDate }) }}",
        "options": {}
      },
      "id": "a1b2c3d4-e5f6-7890-3456-901234567890",
      "name": "Create AFFiNE Todo",
